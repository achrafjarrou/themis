from __future__ import annotations
from pydantic import BaseModel, Field, field_validator, computed_field, ConfigDict
from typing   import Annotated, Optional
from enum     import Enum
from datetime import datetime
import hashlib, json


class RiskLevel(str, Enum):
    UNACCEPTABLE = "unacceptable"
    HIGH         = "high"
    LIMITED      = "limited"
    MINIMAL      = "minimal"
    GPAI         = "gpai"
    UNKNOWN      = "unknown"

class GapStatus(str, Enum):
    COMPLIANT      = "compliant"
    PARTIAL        = "partial"
    MISSING        = "missing"
    NOT_APPLICABLE = "not_applicable"

class Framework(str, Enum):
    EU_AI_ACT   = "eu_ai_act"
    GDPR        = "gdpr"
    NIST_AI_RMF = "nist_ai_rmf"

class SeverityLevel(int, Enum):
    LOW      = 1
    MEDIUM   = 2
    HIGH     = 3
    CRITICAL = 4


# ── EvidenceChain™ ─────────────────────────────────────────────────

class EvidenceLink(BaseModel):
    model_config = ConfigDict(frozen=True)
    step_num:   int   = Field(ge=1)
    step_type:  str         # LEGAL_PREMISE | DOCUMENT_FACT | INFERENCE | CONCLUSION
    source_ref: str         # "Article 13 §2" | "System Doc §4.2"
    claim:      str
    confidence: float = 0.0


class EvidenceChain(BaseModel):
    chain_id:        str
    article_ref:     str
    obligation_text: str
    links:           list[EvidenceLink]
    final_status:    GapStatus
    chain_hash:      str = Field(default="")

    def model_post_init(self, __context) -> None:
        payload = json.dumps([l.model_dump() for l in self.links], sort_keys=True)
        object.__setattr__(self, "chain_hash",
            hashlib.sha256(payload.encode()).hexdigest()[:16])

    @computed_field
    @property
    def avg_confidence(self) -> float:
        if not self.links: return 0.0
        return round(sum(l.confidence for l in self.links) / len(self.links), 3)



# ── ContradictionDetector™ ─────────────────────────────────────────

class Contradiction(BaseModel):
    contradiction_id:   str
    contradiction_type: str  # factual | scope | data | process
    statement_a:     str;  location_a: str
    statement_b:     str;  location_b: str
    legal_risk:      str
    severity:        SeverityLevel

    @field_validator("severity", mode="before")
    @classmethod
    def coerce_severity(cls, v):
        if isinstance(v, int):
            return v
        mapping = {"low": 1, "medium": 2, "high": 3, "critical": 4}
        if isinstance(v, str):
            return mapping.get(v.lower().strip(), 2)
        return 2
    resolution_hint: str



# ── ComplianceGap ──────────────────────────────────────────────────
class ComplianceGap(BaseModel):
    gap_id:       str
    framework:    Framework
    article_num:  str

    
    @field_validator("article_num", mode="before")
    @classmethod
    def normalize_article_num(cls, v) -> str:
        import re as _re
        if v is None:
            return "unknown"
        v = str(v).strip()
        if not v:
            return "unknown"
        # Strip Article/Art. prefix — accept: 5, Art.5, Art 5, Article 52, Annex III
        v = _re.sub(r"^(?:Article|Art\.?)\s*", "", v, flags=_re.IGNORECASE).strip()
        return v if v else "unknown"        mapping = {"low": 1, "medium": 2, "high": 3, "critical": 4}
        if isinstance(v, str):
            return mapping.get(v.lower().strip(), 2)
        return 2
    evidence_chain:      EvidenceChain
    remediation_steps:   list[str] = Field(min_length=1)
    deadline_risk:       Optional[str] = None
    cross_framework_refs:list[str] = Field(default_factory=list)

    
    
    
 if v else "unknown"
# ── Risk Classification ────────────────────────────────────────────
class RiskClassification(BaseModel):
    risk_level:          RiskLevel
    reasoning: str | None = None
    applicable_annexes: list[str] = []
    applicable_articles: list[str] = []
    confidence: float = 0.0
    prohibited_practice: Optional[str] = None


# ── Final Report ──────────────────────────────────────────────────
class ComplianceReport(BaseModel):
    session_id:          str
    generated_at:        datetime = Field(default_factory=datetime.utcnow)
    system_name:         str
    risk_classification: RiskClassification
    gaps:                list[ComplianceGap]
    contradictions:      list[Contradiction]
    frameworks_analyzed: list[Framework]
    overall_confidence:  float
    markdown_report:     str

    @computed_field
    @property
    def compliance_score(self) -> float:
        if not self.gaps: return 100.0
        missing = sum(1 for g in self.gaps if g.status == GapStatus.MISSING)
        partial = sum(1 for g in self.gaps if g.status == GapStatus.PARTIAL)
        ded = (missing * 1.0 + partial * 0.5) / len(self.gaps)
        return round(max(0.0, (1.0 - ded) * 100), 1)

    @computed_field
    @property
    def critical_gaps(self) -> list[ComplianceGap]:
        return [g for g in self.gaps if g.severity == SeverityLevel.CRITICAL]

    @computed_field
    @property
    def evidence_integrity_ok(self) -> bool:
        for gap in self.gaps:
            ec = gap.evidence_chain
            payload  = json.dumps([l.model_dump() for l in ec.links], sort_keys=True)
            expected = hashlib.sha256(payload.encode()).hexdigest()[:16]
            if ec.chain_hash != expected: return False
        return True






